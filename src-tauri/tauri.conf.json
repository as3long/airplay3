{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "AirPlay3",
  "version": "0.1.3",
  "identifier": "com.airplay3.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AirPlay3",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "dragDropEnabled": true,
        "url": "index.html"
      },
      {
        "label": "about",
        "title": "About AirPlay3",
        "width": 440,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": true,
        "resizable": false,
        "minimizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
